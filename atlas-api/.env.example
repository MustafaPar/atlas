# ==============================================================================
# Atlas API — Environment Variables
#
# Copy this file to .env and fill in the values before starting the backend.
# The .env file is gitignored and must never be committed.
# ==============================================================================


# ------------------------------------------------------------------------------
# REQUIRED — JWT signing secret (HS256)
#
# Must be a Base64-encoded string of at least 32 random bytes (256 bits).
# The app will refuse to start if this variable is not set.
#
# Generate on Windows (PowerShell):
#
#   $bytes = New-Object byte[] 32
#   [Security.Cryptography.RandomNumberGenerator]::Fill($bytes)
#   $env:JWT_SECRET = [Convert]::ToBase64String($bytes)
#
# To persist across PowerShell sessions (User scope):
#
#   [System.Environment]::SetEnvironmentVariable("JWT_SECRET", $env:JWT_SECRET, "User")
#
# Generate on macOS / Linux (bash):
#
#   export JWT_SECRET=$(openssl rand -base64 32)
#
# ------------------------------------------------------------------------------
JWT_SECRET=


# ------------------------------------------------------------------------------
# OPTIONAL — PostgreSQL credentials
#
# Defaults match the Docker setup described in the README.
# Change only if you are using a non-default PostgreSQL installation.
# ------------------------------------------------------------------------------
DB_USER=atlas
DB_PASS=atlas


# ------------------------------------------------------------------------------
# OPTIONAL — JWT token expiry
#
# Duration in milliseconds. Default is 86400000 (24 hours).
# ------------------------------------------------------------------------------
JWT_EXPIRY_MS=86400000
